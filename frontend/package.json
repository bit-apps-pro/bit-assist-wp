  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pd": "tsc && vite build",
    "fpd": "cd ../widget-iframe && pnpm i && pnpm build",
    "pda": "npm run pd && npm run fpd",
    "clear-lint-cache": "eslint . --cache --cache-file eslint-cache/eslintcache",
    "i18n:json": "npx po2json ./language/locale.pot ../languages/bitform-btcassist-admin-script.json -f jed1.x",
    "i18n:php": "node ./language/pot-to-php.js ./language/locale.pot ../languages/generatedString.php btcassist",
    "clean": "rimraf node_modules yarn.lock package-lock.json",
    "dev:open": "vite --open",
    "vbuild": "tsc && vite build",
    "preview": "vite preview",
    "mock": "json-server --watch ./Mock_API/api.json --port 9000",
    "test": "jest",
    "dev": "vite --config vite.config.wp.ts",
    "postinstall": "node ./postinstall.js",
    "dev:both": "npx concurrently -c \"#fb7185,#fdba74\" \"yarn dev\" \"cd ../widget-iframe && pnpm dev\" --names=frontend,iframe"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
