{
  "name": "btcassist",
  "private": true,
  "version": "1.0.0",
  "dependencies": {
    "@atomik-color/component": "^1.0.16",
    "@atomik-color/core": "^1.0.12",
    "@babel/preset-typescript": "^7.18.6",
    "@chakra-ui/icons": "^2.0.11",
    "@chakra-ui/react": "^2.3.5",
    "@dnd-kit/core": "^6.0.5",
    "@dnd-kit/modifiers": "^6.0.0",
    "@dnd-kit/sortable": "^7.0.1",
    "@dnd-kit/utilities": "^3.2.0",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@fontsource/outfit": "^4.5.10",
    "@loadable/component": "^5.15.2",
    "@monaco-editor/react": "^4.4.5",
    "@tinymce/tinymce-react": "^4.1.0",
    "@types/loadable__component": "^5.13.4",
    "cors": "^2.8.5",
    "framer-motion": "^7.5.3",
    "fs-extra": "^10.1.0",
    "immer": "^9.0.15",
    "jotai": "^1.8.5",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.4.0",
    "react-query": "^3.39.1",
    "react-router-dom": "^6.4.2",
    "react-select-search": "^4.1.2"
  },
  "scripts": {
    "UNUSED-test": "react-scripts test",
    "UNUSED-start": "react-scripts start",
    "UNUSED-eject": "react-scripts eject",
    "UNUSED-build": "react-scripts build",
    "lint": "eslint --ext .jsx --ext .js --ext .ts --ext .tsx src/ --fix",
    "serve": "webpack serve --progress --color --mode=development",
    "wp": "webpack --progress --color --watch --mode=development",
    "hot": "webpack serve --progress --color --mode=development --hot",
    "fwp": "webpack --progress --color --config webpack.client.config.js --watch --mode=development",
    "pd": "webpack --progress --color --config webpack.config.js --mode=production && npm run i18n:php",
    "fpd": "webpack --progress --color --config webpack.client.config.js --mode=production",
    "pda": "npm run pd && npm run fpd",
    "clear-lint-cache": "eslint . --cache --cache-file eslint-cache/eslintcache",
    "i18n:json": "npx po2json ./language/locale.pot ../languages/bitform-btcassist-admin-script.json -f jed1.x",
    "i18n:php": "node ./language/pot-to-php.js ./language/locale.pot ../languages/generatedString.php btcassist",
    "stat:a": "webpack --profile --json > coverage/a.stats.json",
    "stat:f": "webpack --profile --json > coverage/f.stats.json --config webpack.client.config.js",
    "analyze:f": "webpack-bundle-analyzer coverage/f.stats.json",
    "clean": "rimraf node_modules yarn.lock package-lock.json",
    "dev": "vite --open",
    "vbuild": "tsc && vite build",
    "preview": "vite preview",
    "mock": "json-server --watch ./Mock_API/api.json --port 9000",
    "test": "jest",
    "devv": "vite --config vite.config.wp.ts",
    "postinstall": "node ./postinstall.js"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
  "lint-staged": {
    "**/*.js?(x)": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.18.13",
    "@babel/eslint-parser": "^7.18.9",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-react-jsx": "^7.18.10",
    "@babel/plugin-transform-regenerator": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.18.10",
    "@babel/preset-env": "^7.18.10",
    "@babel/preset-react": "^7.18.6",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/css-modules": "^1.0.2",
    "@types/jest": "^28.1.8",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^5.35.1",
    "@typescript-eslint/parser": "^5.35.1",
    "@vitejs/plugin-react": "^2.0.1",
    "@wordpress/babel-plugin-makepot": "^5.0.0",
    "@wordpress/i18n": "^4.16.0",
    "autoprefixer": "^10.4.8",
    "babel-jest": "^28.1.3",
    "babel-loader": "^8.2.5",
    "clean-webpack-plugin": "^4.0.0",
    "compression-webpack-plugin": "^10.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.1",
    "eslint": "^8.22.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-import-resolver-typescript": "^3.5.0",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.0.1",
    "eslint-plugin-react": "^7.31.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "extract-loader": "^5.1.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.0",
    "husky": "^8.0.1",
    "jest": "^28.1.3",
    "jest-environment-jsdom": "^28.1.3",
    "lint-staged": "^13.0.3",
    "mini-css-extract-plugin": "^2.6.1",
    "mini-svg-data-uri": "^1.4.4",
    "module-to-cdn": "^3.1.5",
    "optimize-css-assets-webpack-plugin": "^6.0.1",
    "postcss-loader": "^7.0.1",
    "postcss-safe-parser": "^6.0.0",
    "prettier": "^2.7.1",
    "react-scripts": "^5.0.1",
    "rimraf": "^3.0.2",
    "style-loader": "^3.3.1",
    "terser-webpack-plugin": "^5.3.5",
    "ts-jest": "^28.0.8",
    "ts-node": "^10.9.1",
    "typescript": "^4.7.4",
    "typescript-plugin-css-modules": "^3.4.0",
    "url-loader": "^4.1.1",
    "vite": "^3.0.9",
    "vite-plugin-pwa": "^0.12.3",
    "webpack": "^5.74.0",
    "webpack-bundle-analyzer": "^4.6.1",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.10.0",
    "webpack-extract-translation-keys-plugin": "^6.0.0",
    "workbox-webpack-plugin": "^6.5.4"
  },
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  }
}
